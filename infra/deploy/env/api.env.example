PORT=4000
APP_ENV=production
APP_VERSION=0.1.0
BASE_URL=https://www.advancewoundbiologic.com
ADMIN_API_KEY=replace-with-long-random-value
ADMIN_LOGIN_EMAIL=admin@advancewoundbiologic.com
ADMIN_LOGIN_PASSWORD=replace-with-long-random-value
ADMIN_SESSION_TTL_SEC=43200
MEMBER_AUTH_SECRET=replace-with-long-random-value
MEMBER_SESSION_TTL_SEC=604800
NIGHTLY_SYNC_CRON=0 2 * * *
SMARTSHEET_REQUIRED=true
SMARTSHEET_ACCESS_TOKEN=replace-me
SMARTSHEET_INTEGRATION_SOURCE=APPLICATION,AWB,Academy
SMARTSHEET_SHEETID_CATALOG=replace-me
SMARTSHEET_SHEETID_QUESTIONBANK=replace-me
SMARTSHEET_SHEETID_RESULTS=replace-me
SMARTSHEET_SHEETID_FORMS=replace-me
SMARTSHEET_SHEETID_IVR=replace-me
SMARTSHEET_WEBHOOK_CALLBACK_URL=https://www.advancewoundbiologic.com/api/smartsheet/webhook
SMARTSHEET_WEBHOOK_SCOPE=sheet
SMARTSHEET_WEBHOOK_SCOPE_OBJECT_ID=replace-me
SMARTSHEET_WEBHOOK_NAME=AWB Academy Sync
SMARTSHEET_WEBHOOK_EVENTS=*.*
CERTIFICATE_ISSUER_NAME=Advance Wound Biologic
CERTIFICATE_ISSUER_LOGO_URL=https://www.advancewoundbiologic.com/logo.png
CERTIFICATE_INSTRUCTOR_NAME=AWB Faculty
CERTIFICATE_CREDIT_HOURS_DEFAULT=See track syllabus
CERTIFICATE_SUPPORT_EMAIL=support@advancewoundbiologic.com
CERTIFICATE_PDF_TOKEN=replace-with-long-random-value
CERTIFICATE_WKHTMLTOPDF_BIN=/usr/bin/wkhtmltopdf
AWS_REGION=us-east-1
CERTIFICATE_PDF_S3_BUCKET=replace-me
VERIFY_RATE_LIMIT_WINDOW_MS=60000
VERIFY_RATE_LIMIT_MAX=60
MEDIA_STORAGE_DIR=/home/ubuntu/.awb-academy/media
VIDEO_GENERATION_DEFAULT_VOICE=Joanna
VIDEO_GENERATION_DEFAULT_PROVIDER=aws-polly
VIDEO_GENERATION_OPENAI_MODEL=gpt-4o-mini-tts
VIDEO_GENERATION_MAX_SCRIPT_CHARS=120000
OPENAI_API_KEY=
DATABASE_URL=postgres://awb:replace-me@127.0.0.1:5432/awb_academy
